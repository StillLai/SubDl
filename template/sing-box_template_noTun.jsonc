{
  "$schema": "https://gh-proxy.org/https://github.com/jiang-zhexin/typebox/releases/latest/download/schema.json",
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "experimental": {
    "clash_api": {
      "default_mode": "Rule",
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://gh-proxy.org/https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip",
      "external_ui_download_detour": "🎯 全球直连"
    },
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "store_rdrc": true
    }
  },
  "dns": {
    "strategy": "prefer_ipv4",
    "servers": [
      {
        "tag": "DNS-Resolver",
        "type": "udp",
        "server": "119.29.29.29"
      },
      {
        "tag": "Tencent-DNS",
        "type": "tls",
        "server": "dot.pub",
        "domain_resolver": "DNS-Resolver"
      },
      {
        "tag": "Ali-DNS",
        "type": "h3",
        "server": "dns.alidns.com",
        "domain_resolver": "DNS-Resolver"
      },
      {
        "tag": "Google-DNS",
        "type": "h3",
        "server": "dns.google",
        "domain_resolver": "DNS-Resolver",
        "detour": "🚀 节点选择"
      },
      {
        "tag": "Cloudflare-DNS",
        "type": "h3",
        "server": "1.1.1.1",
        "detour": "🚀 节点选择"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "server": "Tencent-DNS"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "clash_mode": "Global"
          },
          {
            "inbound": "mixed-in-global"
          }
        ],
        "server": "Google-DNS"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AlwAds",
            "invert": true
          },
          {
            "rule_set": [
              "custom_whitelist",
              "geosite-amazon",
              "geosite-amazon@ads"
            ],
            "invert": true
          },
          {
            "rule_set": [
              "ads",
              "custom_block",
              "WebRTC"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "rule_set": [
              "geosite-icbc",
              "geosite-ccb",
              "geosite-abc",
              "geosite-boc",
              "BOCOM",
              "geosite-cmb"
            ]
          },
          {
            "package_name": [
              "com.icbc",
              "com.chinamworld.main",
              "com.android.bankabc",
              "com.chinamworld.bocmbci",
              "com.bankcomm.Bankcomm",
              "com.cmbchina.ccd.pluto.cmbActivity",
              "cmb.pb"
            ]
          }
        ],
        "server": "Ali-DNS"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "rule_set": [
              "WeChat"
            ]
          },
          {
            "package_name": [
              "com.tencent.mm",
              "tv.danmaku.bili",
              "com.ss.android.ugc.aweme",
              "com.xingin.xhs"
            ]
          }
        ],
        "server": "Tencent-DNS"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "rule_set": [
              "AliPay"
            ]
          },
          {
            "package_name": [
              "com.eg.android.AlipayGphone"
            ]
          }
        ],
        "server": "Ali-DNS"
      },
      {
        "rule_set": [
          "geosite-google",
          "geoip-google",
          "geosite-google-play",
          "geosite-youtube"
        ],
        "server": "Google-DNS"
      },
      {
        "rule_set": [
          "geosite-cloudflare"
        ],
        "server": "Cloudflare-DNS"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": [
              "geosite-geolocation-!cn",
              "custom_proxy"
            ]
          },
          {
            "domain_keyword": "browserleaks",
            "invert": true
          }
        ],
        "server": "Cloudflare-DNS"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": [
              "GeositeCN",
              "geosite-geolocation-cn",
              "custom_direct",
              "XiaoMi"
            ]
          },
          {
            "domain_keyword": "browserleaks",
            "invert": true
          }
        ],
        "server": "Tencent-DNS"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": "geosite-geolocation-!cn",
            "invert": true
          },
          {
            "rule_set": "geoip-cn"
          }
        ],
        "server": "Google-DNS",
        "client_subnet": "113.84.0.1/24"
      },
      {
        "rule_set": [
          "geoip-cn"
        ],
        "invert": true,
        "server": "Cloudflare-DNS"
      }
    ],
    "final": "Google-DNS",
    "client_subnet": "113.84.0.1/24"
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 5297
    },
    {
      "type": "mixed",
      "tag": "mixed-in-global",
      "listen": "127.0.0.1",
      "listen_port": 43210
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "🚀 节点选择",
      "outbounds": [
        "🎈 自动选择",
        "🗂️ 备用自动",
        "🇭🇰 香港节点",
